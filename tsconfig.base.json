{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@cafe-system/types": ["packages/types/src/index.ts"],
      "@cafe-system/utils": ["packages/utils/src/index.ts"],
      "@cafe-system/ui": ["packages/ui/src/index.ts"]
    }
  }
}
