{
  "name": "cafe-system",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "dev": "pnpm -r --parallel --filter ./apps/* dev",
    "dev:web": "pnpm --filter @cafe-system/web dev",
    "dev:api": "pnpm --filter @cafe-system/api dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "check": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
